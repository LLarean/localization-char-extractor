@page "/"
@inject IJSRuntime JS
@implements IDisposable

<div class="container">
    <h1>Localization Char Extractor</h1>

    <div class="section">
        <label>JSON (paste or drag-and-drop a file)</label>
        <div class="drop-zone @(_isDragging ? "dragging" : "")"
             @ref="_dropZoneRef"
             @ondragover:preventDefault
             @ondragenter="() => _isDragging = true"
             @ondragleave="() => _isDragging = false">
            <textarea @bind="_jsonInput" placeholder="Paste JSON here..."></textarea>
        </div>
    </div>

    <div class="section">
        <label>Language (column header, e.g. Japanese)</label>
        <input @bind="_language" placeholder="English" />
    </div>

    <button class="btn-primary" @onclick="Extract">Extract characters</button>

    @if (!string.IsNullOrEmpty(_result))
    {
        <div class="section">
            <label>Unique characters (@_charCount)</label>
            <textarea id="result-output" readonly>@_result</textarea>
            <button class="btn-secondary" @onclick="CopyToClipboard">Copy to clipboard</button>
        </div>
    }

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="error">@_error</div>
    }
</div>

@code {
    private string _jsonInput = "";
    private string _language = "";
    private string _result = "";
    private string _error = "";
    private int _charCount = 0;
    private bool _isDragging = false;
    private ElementReference _dropZoneRef;
    private DotNetObjectReference<Home>? _selfRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("registerDropZone", _dropZoneRef, _selfRef);
        }
    }

    [JSInvokable]
    public void OnFileDropped(string content)
    {
        _jsonInput = content;
        _isDragging = false;
        StateHasChanged();
    }

    private void Extract()
    {
        _error = "";
        _result = "";

        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(_jsonInput);
            var files = doc.RootElement
                .GetProperty("Localization")
                .GetProperty("files")
                .EnumerateArray();

            var chars = new System.Collections.Generic.HashSet<char>();

            foreach (var file in files)
            {
                if (file.GetProperty("name").GetString() != _language) continue;

                var content = file.GetProperty("content").GetString();
                var contentDoc = System.Text.Json.JsonDocument.Parse(content);

                foreach (var prop in contentDoc.RootElement.EnumerateObject())
                    foreach (var c in prop.Value.GetString() ?? "")
                        chars.Add(c);
            }

            if (chars.Count == 0)
            {
                _error = $"Language '{_language}' not found or empty.";
                return;
            }

            var sorted = new System.Collections.Generic.List<char>(chars);
            sorted.Sort();
            _result = string.Concat(sorted);
            _charCount = sorted.Count;
        }
        catch (Exception ex)
        {
            _error = $"Parse error: {ex.Message}";
        }
    }

    private async Task CopyToClipboard()
    {
        await JS.InvokeVoidAsync("copyToClipboard", "result-output");
    }

    public void Dispose() => _selfRef?.Dispose();
}
