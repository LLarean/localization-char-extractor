@page "/"
@inject IJSRuntime JS
@implements IDisposable

<div class="container">
    <h1>Localization Char Extractor</h1>

    @if (_isLoading)
    {
        <div class="file-progress">
            <div class="file-progress-bar"></div>
        </div>
    }

    <div class="section">
        <label>JSON (paste or drag-and-drop a file)</label>
        <div class="drop-zone @(_isDragging ? "dragging" : "")"
             @ref="_dropZoneRef"
             @ondragover:preventDefault
             @ondragenter="() => _isDragging = true"
             @ondragleave="() => _isDragging = false">
            <textarea @bind="_jsonInput" @bind:after="OnJsonChanged" placeholder="Paste JSON here..."></textarea>
            @if (!string.IsNullOrEmpty(_jsonInput))
            {
                <button class="clear-btn" @onclick="ClearJson" title="Clear JSON">×</button>
            }
        </div>
    </div>

    <div class="section">
        @if (_languages.Count > 0)
        {
            <div class="result-header">
                <label>Languages</label>
                <div class="result-actions">
                    <button class="btn-link" @onclick="SelectAllLanguages">all</button>
                    <button class="btn-link" @onclick="DeselectAllLanguages">none</button>
                </div>
            </div>
            <div class="lang-grid">
                @foreach (var lang in _languages)
                {
                    <span class="lang-chip @(_selectedLanguages.Contains(lang) ? "selected" : "")"
                          @onclick="() => ToggleLanguage(lang)">@lang</span>
                }
            </div>
        }
        else
        {
            <label>Language (column header, e.g. Japanese)</label>
            <input @bind="_language" placeholder="English" />
        }
    </div>

    <div class="section">
        <div class="result-header">
            <label>Unicode range</label>
        </div>
        <div class="lang-grid">
            @foreach (var preset in UnicodePresets)
            {
                <span class="lang-chip @(_activePreset == preset.Key ? "selected" : "")"
                      @onclick="() => _activePreset = preset.Key">@preset.Key</span>
            }
        </div>
    </div>

    <div class="extract-row">
        <button class="btn-primary" @onclick="Extract" disabled="@_isExtracting">Extract characters</button>
        <label class="checkbox-label">
            <input type="checkbox" @bind="_includeEmoji" />
            Include emoji
        </label>
    </div>

    @if (_isExtracting)
    {
        <div class="file-progress">
            <div class="file-progress-bar"></div>
        </div>
    }

    @if (_runes.Count > 0)
    {
        <div class="section">
            <div class="result-header">
                <label>Unique characters (@ActiveCharCount@(_excludedRunes.Count > 0 ? $" / {_runes.Count}" : ""))</label>
                <div class="result-actions">
                    <button class="btn-link" @onclick="SelectAll">all</button>
                    <button class="btn-link" @onclick="DeselectAll">none</button>
                </div>
            </div>
            <div class="char-grid">
                @foreach (var (rune, i) in _runes.Select((r, i) => (r, i)))
                {
                    <span class="char-chip @(_excludedRunes.Contains(rune) ? "excluded" : "")"
                          title="U+@(rune.Value.ToString("X4"))"
                          style="animation-delay: @(Math.Min(i * 8, 400))ms"
                          @onclick="() => ToggleRune(rune)">@rune.ToString()</span>
                }
            </div>
            <div class="copy-row">
                <button class="btn-secondary" @onclick="CopyToClipboard">Copy to clipboard</button>
                <div class="result-actions">
                    <button class="btn-link @(_copyFormat == "string" ? "format-active" : "")"
                            @onclick='() => _copyFormat = "string"'>string</button>
                    <button class="btn-link @(_copyFormat == "hex" ? "format-active" : "")"
                            @onclick='() => _copyFormat = "hex"'>U+XXXX</button>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="error">@_error</div>
    }

    <a class="github-link" href="https://github.com/LLarean/localization-char-extractor" target="_blank" rel="noopener noreferrer" title="View on GitHub">
        <svg viewBox="0 0 16 16" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
                     0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13
                     -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66
                     .07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15
                     -.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27
                     .68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12
                     .51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48
                     0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
    </a>
</div>

@code {
    private string _jsonInput = "";
    private string _language = "";
    private string _error = "";
    private List<Rune> _runes = new();
    private HashSet<Rune> _excludedRunes = new();
    private List<string> _languages = new();
    private HashSet<string> _selectedLanguages = new();

    private int ActiveCharCount => _runes.Count - _excludedRunes.Count;
    private bool _includeEmoji = true;
    private string _activePreset = "All";
    private string _copyFormat = "string";

    private static readonly IReadOnlyDictionary<string, (int From, int To)?> UnicodePresets =
        new Dictionary<string, (int, int)?>
        {
            ["All"]      = null,
            ["Latin"]    = (0x0020, 0x024F),
            ["Cyrillic"] = (0x0400, 0x04FF),
            ["Greek"]    = (0x0370, 0x03FF),
            ["Arabic"]   = (0x0600, 0x06FF),
            ["CJK"]      = (0x4E00, 0x9FFF),
        };
    private bool _isDragging = false;
    private bool _isLoading = false;
    private bool _isExtracting = false;
    private ElementReference _dropZoneRef;
    private DotNetObjectReference<Home>? _selfRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("registerDropZone", _dropZoneRef, _selfRef);
            await JS.InvokeVoidAsync("registerKeyboardShortcuts", _selfRef);

            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "lce_json");
            if (!string.IsNullOrEmpty(saved))
            {
                _jsonInput = saved;
                ParseLanguages();
                StateHasChanged();
            }
        }
    }

    [JSInvokable]
    public void SetLoading(bool loading)
    {
        _isLoading = loading;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnFileDropped(string content)
    {
        _jsonInput = content;
        _isDragging = false;
        _isLoading = false;
        OnJsonChanged();
        StateHasChanged();
    }

    [JSInvokable]
    public Task TriggerExtract() => Extract();

    private void OnJsonChanged()
    {
        ParseLanguages();
        _ = JS.InvokeVoidAsync("localStorage.setItem", "lce_json", _jsonInput);
    }

    private void ParseLanguages()
    {
        _languages.Clear();
        _selectedLanguages.Clear();
        if (string.IsNullOrWhiteSpace(_jsonInput)) return;
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(_jsonInput);
            foreach (var file in doc.RootElement.GetProperty("Localization").GetProperty("files").EnumerateArray())
            {
                var name = file.GetProperty("name").GetString();
                if (!string.IsNullOrEmpty(name))
                    _languages.Add(name);
            }

            if (_languages.Count > 0)
                _selectedLanguages.Add(_languages[0]);
        }
        catch { }
    }

    private async Task Extract()
    {
        _error = "";
        _runes = new();
        _excludedRunes.Clear();
        _isExtracting = true;
        await Task.Yield();

        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(_jsonInput);
            var files = doc.RootElement
                .GetProperty("Localization")
                .GetProperty("files")
                .EnumerateArray();

            var targets = _languages.Count > 0
                ? _selectedLanguages
                : (string.IsNullOrWhiteSpace(_language) ? [] : new HashSet<string> { _language });

            if (targets.Count == 0)
            {
                _error = "Please select at least one language.";
                return;
            }

            var runeSet = new HashSet<Rune>();
            var range = UnicodePresets[_activePreset];

            foreach (var file in files)
            {
                if (!targets.Contains(file.GetProperty("name").GetString() ?? "")) continue;

                var content = file.GetProperty("content").GetString();
                var contentDoc = System.Text.Json.JsonDocument.Parse(content);

                foreach (var prop in contentDoc.RootElement.EnumerateObject())
                    foreach (var rune in (prop.Value.GetString() ?? "").EnumerateRunes())
                        if (rune.Value > 31 && rune.Value != 127
                            && (_includeEmoji || !IsEmoji(rune))
                            && (range is null || rune.Value >= range.Value.From && rune.Value <= range.Value.To))
                            runeSet.Add(rune);
            }

            if (runeSet.Count == 0)
            {
                _error = "No characters found for the selected language(s).";
                return;
            }

            _runes = runeSet.OrderBy(r => r.Value).ToList();
        }
        catch (Exception ex)
        {
            _error = $"Parse error: {ex.Message}";
        }
        finally
        {
            _isExtracting = false;
        }
    }

    private static bool IsEmoji(Rune rune) =>
        rune.Value is (>= 0x2600 and <= 0x27BF)  // Miscellaneous Symbols, Dingbats
        or >= 0x1F000;                             // Supplementary emoji blocks

    private void ToggleLanguage(string lang)
    {
        if (!_selectedLanguages.Remove(lang))
            _selectedLanguages.Add(lang);
    }

    private void SelectAllLanguages() => _selectedLanguages = new(_languages);

    private void DeselectAllLanguages() => _selectedLanguages.Clear();

    private void ToggleRune(Rune rune)
    {
        if (!_excludedRunes.Remove(rune))
            _excludedRunes.Add(rune);
    }

    private void SelectAll() => _excludedRunes.Clear();

    private void DeselectAll() => _excludedRunes = new(_runes);

    private void ClearJson()
    {
        _jsonInput = "";
        _languages.Clear();
        _selectedLanguages.Clear();
        _runes.Clear();
        _excludedRunes.Clear();
        _error = "";
        _ = JS.InvokeVoidAsync("localStorage.removeItem", "lce_json");
    }

    private async Task CopyToClipboard()
    {
        var active = _runes.Where(r => !_excludedRunes.Contains(r));
        var text = _copyFormat == "hex"
            ? string.Join(" ", active.Select(r => $"U+{r.Value:X4}"))
            : string.Concat(active);
        await JS.InvokeVoidAsync("copyToClipboard", text);
    }

    public void Dispose() => _selfRef?.Dispose();
}
