@page "/"
@inject IJSRuntime JS
@implements IDisposable

<div class="container">
    <h1>Localization Char Extractor</h1>

    @if (_isLoading)
    {
        <div class="file-progress">
            <div class="file-progress-bar"></div>
        </div>
    }

    <div class="section">
        <label>JSON (paste or drag-and-drop a file)</label>
        <div class="drop-zone @(_isDragging ? "dragging" : "")"
             @ref="_dropZoneRef"
             @ondragover:preventDefault
             @ondragenter="() => _isDragging = true"
             @ondragleave="() => _isDragging = false">
            <textarea @bind="_jsonInput" @bind:after="ParseLanguages" placeholder="Paste JSON here..."></textarea>
        </div>
    </div>

    <div class="section">
        <label>Language (column header, e.g. Japanese)</label>
        <input @bind="_language" list="language-list" placeholder="English" />
        <datalist id="language-list">
            @foreach (var lang in _languages)
            {
                <option value="@lang" />
            }
        </datalist>
    </div>

    <button class="btn-primary" @onclick="Extract" disabled="@_isExtracting">Extract characters</button>

    @if (_isExtracting)
    {
        <div class="file-progress">
            <div class="file-progress-bar"></div>
        </div>
    }

    @if (_runes.Count > 0)
    {
        <div class="section">
            <label>Unique characters (@_charCount)</label>
            <div class="char-grid">
                @foreach (var rune in _runes)
                {
                    <span class="char-chip">@rune.ToString()</span>
                }
            </div>
            <button class="btn-secondary" @onclick="CopyToClipboard">Copy to clipboard</button>
        </div>
    }

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="error">@_error</div>
    }
</div>

@code {
    private string _jsonInput = "";
    private string _language = "";
    private string _result = "";
    private string _error = "";
    private int _charCount = 0;
    private List<Rune> _runes = new();
    private List<string> _languages = new();
    private bool _isDragging = false;
    private bool _isLoading = false;
    private bool _isExtracting = false;
    private ElementReference _dropZoneRef;
    private DotNetObjectReference<Home>? _selfRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("registerDropZone", _dropZoneRef, _selfRef);
        }
    }

    [JSInvokable]
    public void SetLoading(bool loading)
    {
        _isLoading = loading;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnFileDropped(string content)
    {
        _jsonInput = content;
        _isDragging = false;
        _isLoading = false;
        ParseLanguages();
        StateHasChanged();
    }

    private void ParseLanguages()
    {
        _languages.Clear();
        if (string.IsNullOrWhiteSpace(_jsonInput)) return;
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(_jsonInput);
            foreach (var file in doc.RootElement.GetProperty("Localization").GetProperty("files").EnumerateArray())
            {
                var name = file.GetProperty("name").GetString();
                if (!string.IsNullOrEmpty(name))
                    _languages.Add(name);
            }
        }
        catch { }
    }

    private async Task Extract()
    {
        _error = "";
        _result = "";
        _runes = new();
        _isExtracting = true;
        await Task.Yield();

        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(_jsonInput);
            var files = doc.RootElement
                .GetProperty("Localization")
                .GetProperty("files")
                .EnumerateArray();

            var runeSet = new HashSet<Rune>();

            foreach (var file in files)
            {
                if (file.GetProperty("name").GetString() != _language) continue;

                var content = file.GetProperty("content").GetString();
                var contentDoc = System.Text.Json.JsonDocument.Parse(content);

                foreach (var prop in contentDoc.RootElement.EnumerateObject())
                    foreach (var rune in (prop.Value.GetString() ?? "").EnumerateRunes())
                        if (rune.Value > 31 && rune.Value != 127)
                            runeSet.Add(rune);
            }

            if (runeSet.Count == 0)
            {
                _error = $"Language '{_language}' not found or empty.";
                return;
            }

            _runes = runeSet.OrderBy(r => r.Value).ToList();
            _result = string.Concat(_runes);
            _charCount = _runes.Count;
        }
        catch (Exception ex)
        {
            _error = $"Parse error: {ex.Message}";
        }
        finally
        {
            _isExtracting = false;
        }
    }

    private async Task CopyToClipboard()
    {
        await JS.InvokeVoidAsync("copyToClipboard", _result);
    }

    public void Dispose() => _selfRef?.Dispose();
}
